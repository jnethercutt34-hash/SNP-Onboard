# ── AI Provider ──────────────────────────────────────────────────────────────
#
# Controls which backend the /api/chat route uses.
#
#   mock      — hardcoded responses from src/lib/mock-ai.ts (default, no API needed)
#   internal  — company AI via OpenAI-compatible API (configure below)
#   gemini    — Genkit/Gemini (not yet implemented)
#
NEXT_PUBLIC_AI_PROVIDER=internal

# ── Company AI (OpenAI-compatible) ───────────────────────────────────────────
#
# Base URL of your company's OpenAI-compatible endpoint.
# e.g. https://ai.company.internal/v1
#
GDMS_AI_ENDPOINT=https://your-company-ai.example.com/v1

# API key / bearer token for authentication.
GDMS_AI_AUTH_TOKEN=your-api-key-here

# Model name to request. Use whatever your company's deployment exposes.
# e.g. gpt-4, gpt-4o, llama-3-70b, etc.
GDMS_AI_MODEL=gpt-4
